{
  "operationId": "viewsList",
  "path": "/views.list",
  "method": "POST",
  "summary": "List all views",
  "tags": [
    "Views"
  ],
  "requestSchema": {
    "type": "object",
    "properties": {
      "documentId": {
        "type": "string",
        "format": "uuid",
        "description": "The document ID to retrieve views for"
      },
      "includeSuspended": {
        "type": "boolean",
        "description": "Whether to include views from suspended users",
        "default": false
      }
    },
    "required": [
      "documentId"
    ]
  }
}