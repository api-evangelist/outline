        "format": "uuid"
      },
      "userId": {
        "type": "string",
        "description": "Identifier for the user to add to the collection",
        "format": "uuid"
      },
      "permission": {
        "$ref": "#/components/schemas/Permission"
      }
    },
    "required": [
      "id",
      "userId"
    ]
  }
}